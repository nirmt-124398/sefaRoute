# Database
DATABASE_URL=postgresql://postgres:saferoute@localhost:5432/saferoute
DB_SCHEMA=public

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# Encryption (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# PostHog (optional — leave blank to disable)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# App
APP_ENV=development
